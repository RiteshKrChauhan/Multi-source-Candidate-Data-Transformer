# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Python bytecode & caches ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ── Distribution / packaging ──────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
MANIFEST

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.lcov

# ── Type-checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
.pytype/

# ── IDE / editor settings ─────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── Project-specific: keep the output directory tracked but ignore generated files ──
output/*.json
!output/.gitkeep
